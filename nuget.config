<?xml version="1.0" encoding="utf-8"?>
<!-- Pin this repo to nuget.org: everything here is public, and machine-level
     corporate feeds don't carry the NativeAOT ILCompiler/runtime packs. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
